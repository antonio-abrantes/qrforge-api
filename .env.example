# =============================================================================
# QRForge — template do .env de DEPLOY (Swarm / Portainer)
# Copie para `.env` na VPS (ou importe no Portainer). Não commitar o `.env` real.
#
# Nomes QRAPI_* = o que o stack.yml interpola.
# Dentro do container viram DATABASE_URL, REDIS_URL, ADMIN_API_KEY, etc.
# =============================================================================

QRAPI_DATABASE_URL=postgres://qrapi:CHANGE_ME@qrapi-postgres:5432/qrapi
QRAPI_DB_PASSWORD=CHANGE_ME
QRAPI_DB_USER=qrapi
QRAPI_DB_NAME=qrapi
QRAPI_REDIS_URL=redis://qrapi-redis:6379
QRAPI_ADMIN_API_KEY=replace-with-openssl-rand-hex-64

QRAPI_PUBLIC_HOST=seudominio.com.br
QRAPI_CORS_ORIGIN=*
QRAPI_LOG_LEVEL=info

QRAPI_RATE_LIMIT_MAX=60
QRAPI_RATE_LIMIT_TIME_WINDOW_MS=60000
QRAPI_BATCH_MAX_ITEMS=500
QRAPI_BATCH_BASE64_MAX_ITEMS=200
QRAPI_CACHE_TTL_SECONDS=300
QRAPI_IMAGE_FETCH_TIMEOUT_MS=5000
QRAPI_IMAGE_FETCH_MAX_BYTES=2097152

