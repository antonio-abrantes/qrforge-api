NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Local default: Postgres nativo (Windows/macOS/Linux) com senha 123456.
# `pnpm db:migrate` cria o banco (qrapi) se não existir — role precisa de CREATEDB.
# Alternativa (compose): postgres://qrapi:qrapi@localhost:5432/qrapi
DATABASE_URL=postgres://postgres:123456@localhost:5432/qrapi

# DB de manutenção usado só para CREATE DATABASE (default: postgres).
# POSTGRES_MAINTENANCE_DB=postgres

# Redis: use compose (`docker compose up -d redis`) ou instância local/VPS.
REDIS_URL=redis://localhost:6379

# Gere com: openssl rand -hex 64
ADMIN_API_KEY=replace-with-openssl-rand-hex-64

CORS_ORIGIN=*
LOG_LEVEL=debug
RATE_LIMIT_MAX=60
RATE_LIMIT_TIME_WINDOW_MS=60000
BATCH_MAX_ITEMS=500
BATCH_BASE64_MAX_ITEMS=200
CACHE_TTL_SECONDS=300
IMAGE_FETCH_TIMEOUT_MS=5000
IMAGE_FETCH_MAX_BYTES=2097152
